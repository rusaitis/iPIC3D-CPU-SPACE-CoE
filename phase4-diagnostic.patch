+//! Phase 4 diagnostic: measure self-adjointness of the Maxwell operator
+//  and its sub-operators (curl-curl, smoothing, mass matrix).
+//  Called once on cycle 1 from calculateE().
+//
+//  CRITICAL: Random test vectors must be globally consistent on MPI-shared
+//  boundary nodes. We use a deterministic hash of the global node index so
+//  that both ranks generate the same value for the same physical node.
+void EMfields3D::diagnoseOperatorSymmetry(int krylov_size)
+{
+    const Collective *col = &get_col();
+    const VirtualTopology3D *vct = &get_vct();
+    const int rank = vct->getCartesian_rank();
+
+    // Global grid dimensions and rank coordinates for consistent random fill
+    const int nxc_global = col->getNxc();
+    const int nyc_global = col->getNyc();
+    const int nzc_global = col->getNzc();
+    const int nxc_r = nxc_global / vct->getXLEN();
+    const int nyc_r = nyc_global / vct->getYLEN();
+    const int nzc_r = nzc_global / vct->getZLEN();
+    const int rx = vct->getCoordinates(0);
+    const int ry = vct->getCoordinates(1);
+    const int rz = vct->getCoordinates(2);
+
+    // Deterministic hash: maps global node index → uniform double in [-0.5, 0.5]
+    // Different seed values produce independent random fields.
+    auto hash_val = [&](int gi, int gj, int gk, unsigned seed) -> double {
+        // Wrap periodic indices
+        gi = gi % nxc_global; if (gi < 0) gi += nxc_global;
+        gj = gj % nyc_global; if (gj < 0) gj += nyc_global;
+        gk = gk % nzc_global; if (gk < 0) gk += nzc_global;
+        unsigned h = (unsigned)gi * 73856093u ^ (unsigned)gj * 19349663u
+                   ^ (unsigned)gk * 83492791u ^ seed * 1000000007u;
+        h = (h ^ (h >> 16)) * 0x45d9f3bu;
+        h = (h ^ (h >> 16)) * 0x45d9f3bu;
+        h = h ^ (h >> 16);
+        return (double)(h & 0xFFFFFFu) / (double)0xFFFFFFu - 0.5;
+    };
+
+    // Fill a 3D array with globally-consistent random data (interior only)
+    auto fill_consistent = [&](double ***arr, unsigned seed) {
+        for (int i = 0; i < nxn; i++)
+            for (int j = 0; j < nyn; j++)
+                for (int k = 0; k < nzn; k++)
+                    arr[i][j][k] = 0.0;
+        for (int i = n_ghost_; i < nxn - n_ghost_; i++)
+            for (int j = n_ghost_; j < nyn - n_ghost_; j++)
+                for (int k = n_ghost_; k < nzn - n_ghost_; k++) {
+                    int gi = (i - n_ghost_) + rx * nxc_r;
+                    int gj = (j - n_ghost_) + ry * nyc_r;
+                    int gk = (k - n_ghost_) + rz * nzc_r;
+                    arr[i][j][k] = hash_val(gi, gj, gk, seed);
+                }
+    };
+
+    if (rank == 0)
+        printf("\n========== PHASE 4: OPERATOR SYMMETRY DIAGNOSTIC ==========\n"
+               "  stencil = %s, n_ghost = %d, num_smoothings = %d\n"
+               "  grid per rank: %dx%dx%d nodes, krylov_size = %d\n"
+               "  global grid: %dx%dx%d cells, topology: %dx%dx%d\n\n",
+               (n_ghost_ == 1 ? "CIC" : "TSC"), n_ghost_, num_smoothings,
+               nxn - 2*n_ghost_, nyn - 2*n_ghost_, nzn - 2*n_ghost_, krylov_size,
+               nxc_global, nyc_global, nzc_global,
+               vct->getXLEN(), vct->getYLEN(), vct->getZLEN());
+
+    //--- Build Krylov vectors from globally-consistent 3D fields ---
+    // Use tempX/Y/Z as scratch for building the Krylov vectors
+    double *u = new double[krylov_size];
+    double *v = new double[krylov_size];
+    double *Au = new double[krylov_size];
+    double *Av = new double[krylov_size];
+
+    // Build u: 3 components with seeds 10, 11, 12
+    for (int i = 0; i < nxn; i++)
+        for (int j = 0; j < nyn; j++)
+            for (int k = 0; k < nzn; k++) {
+                tempX[i][j][k] = tempY[i][j][k] = tempZ[i][j][k] = 0.0;
+            }
+    for (int i = n_ghost_; i < nxn - n_ghost_; i++)
+        for (int j = n_ghost_; j < nyn - n_ghost_; j++)
+            for (int k = n_ghost_; k < nzn - n_ghost_; k++) {
+                int gi = (i - n_ghost_) + rx * nxc_r;
+                int gj = (j - n_ghost_) + ry * nyc_r;
+                int gk = (k - n_ghost_) + rz * nzc_r;
+                tempX[i][j][k] = hash_val(gi, gj, gk, 10);
+                tempY[i][j][k] = hash_val(gi, gj, gk, 11);
+                tempZ[i][j][k] = hash_val(gi, gj, gk, 12);
+            }
+    phys2solver(u, tempX, tempY, tempZ, nxn, nyn, nzn, n_ghost_);
+
+    // Build v: 3 components with seeds 20, 21, 22
+    for (int i = n_ghost_; i < nxn - n_ghost_; i++)
+        for (int j = n_ghost_; j < nyn - n_ghost_; j++)
+            for (int k = n_ghost_; k < nzn - n_ghost_; k++) {
+                int gi = (i - n_ghost_) + rx * nxc_r;
+                int gj = (j - n_ghost_) + ry * nyc_r;
+                int gk = (k - n_ghost_) + rz * nzc_r;
+                tempX[i][j][k] = hash_val(gi, gj, gk, 20);
+                tempY[i][j][k] = hash_val(gi, gj, gk, 21);
+                tempZ[i][j][k] = hash_val(gi, gj, gk, 22);
