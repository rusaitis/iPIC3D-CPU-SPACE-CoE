+    MaxwellImage(Av, v);
+    skip_mass_matrix_diag_ = false;
+
+    double loc_cc[4] = {0, 0, 0, 0};
+    for (int i = 0; i < krylov_size; i++) {
+        loc_cc[0] += v[i] * Au[i];
+        loc_cc[1] += u[i] * Av[i];
+        loc_cc[2] += u[i] * u[i];
+        loc_cc[3] += v[i] * v[i];
+    }
+    double glb_cc[4];
+    MPI_Allreduce(loc_cc, glb_cc, 4, MPI_DOUBLE, MPI_SUM, MPI_COMM_WORLD);
+
+    double delta_cc = fabs(glb_cc[0] - glb_cc[1]) / (sqrt(glb_cc[2]) * sqrt(glb_cc[3]));
+    if (rank == 0) {
