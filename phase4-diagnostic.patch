+    //=== 4b: Smoothing operator S symmetry ===
+    double ***su = newArr3(double, nxn, nyn, nzn);
+    double ***sv = newArr3(double, nxn, nyn, nzn);
+    double ***su_orig = newArr3(double, nxn, nyn, nzn);
+    double ***sv_orig = newArr3(double, nxn, nyn, nzn);
