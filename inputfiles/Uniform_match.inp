###! Uniform plasma counterpart to DoubleGEM_match.inp.
###! Same grid, dt, cycles, MPI topology, periodic BCs — but NO Harris sheet,
###! NO perturbation, uniform B0. If the Step 34d residual ~6e-7 is driven by
###! current-sheet / gradient features, this should be MUCH smaller.
###! If it's the same, the gap is intrinsic to the discretization.

Case                           = Maxwellian
SimulationName                 = Uniform_match
SaveDirName                    = output/uniform_match
RestartDirName                 = output/uniform_match

WriteMethod                    = shdf5
output_data_precision          = DOUBLE
restart_status                 = 0

DiagnosticsOutputCycle         = 1
RestartOutputCycle             = 0
FieldOutputCycle               = 0
ParticlesOutputCycle           = 0
ParticlesDownsampleOutputCycle = 0
ParticlesDownsampleFactor      = 1

FieldOutputTag                 = B + E + rho + J
ParticlesOutputTag             = position + velocity + q
ParticlesDownsampleOutputTag   = position_DS + velocity_DS + q_DS

#* Match DoubleGEM operator conventions (self-adjoint lap+graddiv, one-sided S on E).
MaxwellOperator                = lap_graddiv


#* Weak uniform B, no perturbation
B0x                            = 0.0097
B0y                            = 0.0
B0z                            = 0.0

dt                             = 0.1
ncycles                        = 100
th                             = 0.5
c                              = 1.0
GMREStol                       = 1E-15

Smooth                         = 0
num_smoothings                 = 0
SmoothCycle                    = 1

Lx                             = 12.5
Ly                             = 25.0
Lz                             = 1.0

nxc                            = 256
nyc                            = 128
nzc                            = 1

XLEN                           = 1
YLEN                           = 1
ZLEN                           = 1

ns                             = 2
rhoINIT                        = 1.0    1.0
rhoINJECT                      = 0.0    0.0

npcelx                         = 2      2
npcely                         = 2      2
npcelz                         = 2      2
NpMaxNpRatio                   = 3.0

qom                            = -256.0 1.0

uth                            = 0.045  0.0063
vth                            = 0.045  0.0063
wth                            = 0.045  0.0063

u0                             = 0.0    0.0
v0                             = 0.0    0.0
w0                             = 0.0    0.0

PERIODICX                      = 1
PERIODICY                      = 1
PERIODICZ                      = 1
