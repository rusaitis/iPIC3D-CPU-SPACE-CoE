###! Lapenta-2023 S-symmetry probe on DoubleGEM (2-cycle, same grid as AdjointProbe.inp).
###! Applies the smoothing operator S to two deterministic pseudo-random Krylov vectors
###! and prints <S*u, v> - <u, S*v>. The 2023 paper requires S to be a symmetric matrix
###! for exact energy conservation when EnergyConservingSmoothing is on.

Case                           = Double_Harris
SimulationName                 = SmoothProbe
SaveDirName                    = output/smooth_probe
RestartDirName                 = output/smooth_probe

WriteMethod                    = shdf5
output_data_precision          = DOUBLE
restart_status                 = 0

DiagnosticsOutputCycle         = 1
RestartOutputCycle             = 0
FieldOutputCycle               = 0
ParticlesOutputCycle           = 0
ParticlesDownsampleOutputCycle = 0
ParticlesDownsampleFactor      = 1

FieldOutputTag                 = B + E + rho + J
ParticlesOutputTag             = position + velocity + q
ParticlesDownsampleOutputTag   = position_DS + velocity_DS + q_DS

MaxwellOperator                = lap_graddiv
EnergyConservingSmoothing      = true
FixNodePeriodicHalo            = true
UnifyPeriodicDuplicates        = true
VerifyAdjoint                  = false
VerifySmoothSymmetry           = true
SolverType                     = PETSc

nparam                         = 2
custom_parameters              = 0.1        0.5

B0x                            = 0.0097
B0y                            = 0.0
B0z                            = 0.0

dt                             = 0.1
ncycles                        = 2
th                             = 0.5
c                              = 1.0
GMREStol                       = 1E-15

# Smoothing gate: the probe calls energy_conserve_smooth_direction directly
# (bypassing the SmoothCycle/Smooth gate), so these values don't affect the
# probe but keep the binomial kernel selection as the default.
Smooth                         = 0
num_smoothings                 = 0
SmoothCycle                    = 1

Lx                             = 12.5
Ly                             = 25.0
Lz                             = 1.0

nxc                            = 256
nyc                            = 128
nzc                            = 1

XLEN                           = 1
YLEN                           = 1
ZLEN                           = 1

ns                             = 4
rhoINIT                        = 1.0    1.0    1.0    1.0
rhoINJECT                      = 0.0    0.0    0.0    0.0

npcelx                         = 2      2      2      2
npcely                         = 2      2      2      2
npcelz                         = 2      2      2      2
NpMaxNpRatio                   = 3.0

qom                            = -256.0 1.0   -256.0  1.0

uth                            = 0.045  0.0063 0.045  0.0063
vth                            = 0.045  0.0063 0.045  0.0063
wth                            = 0.045  0.0063 0.045  0.0063

u0                             = 0.0    0.0    0.0    0.0
v0                             = 0.0    0.0    0.0    0.0
w0                             = 0.0    0.0    0.01  -0.01

PERIODICX                      = 1
PERIODICY                      = 1
PERIODICZ                      = 1
