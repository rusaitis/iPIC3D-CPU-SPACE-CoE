###! Double Harris test case — 100x80x1 grid, 30 cycles, pressure tensor output

Case                           = Double_Harris
SimulationName                 = Double_Harris_test
SaveDirName                    = output/data_dh_test
RestartDirName                 = output/data_dh_test

# ---- OUTPUT ----
WriteMethod                    = phdf5
output_data_precision          = DOUBLE
restart_status                 = 0

DiagnosticsOutputCycle         = 10
RestartOutputCycle             = 0
FieldOutputCycle               = 10
ParticlesOutputCycle           = 10
ParticlesDownsampleOutputCycle = 0
ParticlesDownsampleFactor      = 1

FieldOutputTag                 = B + E + rho + J + J_s + rho_s + pressure
ParticlesOutputTag             = position + velocity + q
ParticlesDownsampleOutputTag   = position_DS + velocity_DS + q_DS

# ---- PHYSICS ----
nparam                         = 2
custom_parameters              = 0.4        0.25

B0x                            = 0.097
B0y                            = 0.0
B0z                            = 0.0

# ---- TIME ----
dt                             = 0.125
ncycles                        = 30
th                             = 0.5
c                              = 1.0
GMREStol                       = 1E-15

# ---- SMOOTHING ----
Smooth                         = 1
num_smoothings                 = 4
SmoothCycle                    = 1

# ---- BOX ----
Lx                             = 30.0
Ly                             = 24.0
Lz                             = 1.0

nxc                            = 100
nyc                            = 80
nzc                            = 1

# ---- MPI TOPOLOGY ----
XLEN                           = 2
YLEN                           = 4
ZLEN                           = 1

# ---- PARTICLES ----
ns                  = 4
rhoINIT             = 1.0           1.0             1.0             1.0
rhoINJECT           = 0.0           0.0             0.0             0.0

npcelx              = 5             5               5               5
npcely              = 5             5               5               5
npcelz              = 1             1               1               1
NpMaxNpRatio        = 6.0

qom                 = -256.0        1.0            -256.0          1.0

uth                 = 0.06          0.0063          0.06           0.0063
vth                 = 0.02          0.0063          0.02           0.0063
wth                 = 0.02          0.0063          0.02           0.0063

u0                  = 0.0           0.0             0.0             0.0
v0                  = 0.0           0.0             0.0             0.0
w0                  = 0.00325       -0.01624        0.0             0.0

# ---- BOUNDARY CONDITIONS ----
PERIODICX                      = 1
PERIODICY                      = 1
PERIODICZ                      = 1
